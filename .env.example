# Copia este archivo como .env y ajusta los valores.
# Docker Compose lo carga automaticamente al levantar el contenedor.

# auto = solo genera dataset si no existe. force = lo regenera siempre.
UNIFICAR=auto

# Puerto interno de Streamlit (debe coincidir con el mapeo en docker-compose.yml).
STREAMLIT_SERVER_PORT=8501

# Identificador opcional para aislar el estado por usuario en la app.
# Cada persona debe poner el suyo (no compartir).
APP_USER_ID=
